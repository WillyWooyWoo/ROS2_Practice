<?xml version="1.0"?>
<robot name="basic_arm">

  <material name="red"><color rgba="1 0 0 1"/></material>
  <material name="white"><color rgba="1 1 1 1"/></material>
  <material name="yellow"><color rgba="1 1 0 1"/></material>
  
  <link name="world"/>
  <joint name="fixed_base_joint" type="fixed">
    <parent link="world"/>
    <child link="base_link"/>
  </joint>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <geometry><cylinder radius="0.1" length="0.05"/></geometry>
      <material name="red"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <geometry><cylinder radius="0.1" length="0.05"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <mass value="1.0"/>
      <inertia ixx="0.0027" ixy="0.0" ixz="0.0" iyy="0.0027" iyz="0.0" izz="0.005"/>
    </inertial>
  </link>

  <joint name="arm_0_joint" type="revolute">
    <parent link="base_link"/><child link="link_1"/>
    <origin xyz="0 0 0.05" rpy="0 0 0"/><axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" effort="100" velocity="1.0"/>
  </joint>

  <link name="link_1">
    <visual>
      <origin xyz="0 0 0.15" rpy="0 0 0"/>
      <geometry><cylinder radius="0.04" length="0.3"/></geometry>
      <material name="white"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.15" rpy="0 0 0"/>
      <geometry><cylinder radius="0.04" length="0.3"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.15" rpy="0 0 0"/>
      <mass value="1.0"/>
      <inertia ixx="0.0079" ixy="0.0" ixz="0.0" iyy="0.0079" iyz="0.0" izz="0.0008"/>
    </inertial>
  </link>

  <joint name="arm_1_joint" type="revolute">
    <parent link="link_1"/><child link="link_2"/>
    <origin xyz="0 0 0.3" rpy="0 0 0"/><axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="100" velocity="1.0"/>
  </joint>

  <link name="link_2">
    <visual>
      <origin xyz="0 0 0.15" rpy="0 0 0"/>
      <geometry><cylinder radius="0.035" length="0.3"/></geometry>
      <material name="red"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.15" rpy="0 0 0"/>
      <geometry><cylinder radius="0.035" length="0.3"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.15" rpy="0 0 0"/>
      <mass value="1.0"/>
      <inertia ixx="0.0078" ixy="0.0" ixz="0.0" iyy="0.0078" iyz="0.0" izz="0.0006"/>
    </inertial>
  </link>

  <joint name="arm_2_joint" type="revolute">
    <parent link="link_2"/><child link="link_3"/>
    <origin xyz="0 0 0.3" rpy="0 0 0"/><axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="100" velocity="1.0"/>
  </joint>

  <link name="link_3">
    <visual>
      <origin xyz="0 0 0.1" rpy="0 0 0"/>
      <geometry><cylinder radius="0.03" length="0.2"/></geometry>
      <material name="white"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.1" rpy="0 0 0"/>
      <geometry><cylinder radius="0.03" length="0.2"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.1" rpy="0 0 0"/>
      <mass value="0.5"/>
      <inertia ixx="0.0018" ixy="0.0" ixz="0.0" iyy="0.0018" iyz="0.0" izz="0.0002"/>
    </inertial>
  </link>

  <joint name="gripper_base_joint" type="fixed">
    <parent link="link_3"/><child link="gripper_base"/>
    <origin xyz="0 0 0.2" rpy="0 0 0"/>
  </joint>

  <link name="gripper_base">
    <visual>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <geometry><box size="0.15 0.05 0.05"/></geometry>
      <material name="yellow"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <geometry><box size="0.15 0.05 0.05"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <mass value="0.2"/>
      <inertia ixx="0.00008" ixy="0.0" ixz="0.0" iyy="0.0004" iyz="0.0" izz="0.0004"/>
    </inertial>
  </link>

  <joint name="gripper_1_joint" type="prismatic">
    <parent link="gripper_base"/><child link="gripper_jaw_1"/>
    <origin xyz="0.05 0 0.05" rpy="0 0 0"/><axis xyz="1 0 0"/>
    <limit lower="0.0" upper="0.03" effort="50" velocity="0.5"/>
  </joint>

  <link name="gripper_jaw_1">
    <visual>
      <origin xyz="0 0 0.04" rpy="0 0 0"/>
      <geometry><box size="0.01 0.04 0.08"/></geometry>
      <material name="yellow"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.04" rpy="0 0 0"/>
      <geometry><box size="0.01 0.04 0.08"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.04" rpy="0 0 0"/>
      <mass value="0.05"/>
      <inertia ixx="0.00003" ixy="0.0" ixz="0.0" iyy="0.00003" iyz="0.0" izz="0.00001"/>
    </inertial>
  </link>

  <joint name="gripper_2_joint" type="prismatic">
    <parent link="gripper_base"/><child link="gripper_jaw_2"/>
    <origin xyz="-0.05 0 0.05" rpy="0 0 0"/><axis xyz="-1 0 0"/>
    <limit lower="0.0" upper="0.03" effort="50" velocity="0.5"/>
  </joint>

  <link name="gripper_jaw_2">
    <visual>
      <origin xyz="0 0 0.04" rpy="0 0 0"/>
      <geometry><box size="0.01 0.04 0.08"/></geometry>
      <material name="yellow"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.04" rpy="0 0 0"/>
      <geometry><box size="0.01 0.04 0.08"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.04" rpy="0 0 0"/>
      <mass value="0.05"/>
      <inertia ixx="0.00003" ixy="0.0" ixz="0.0" iyy="0.00003" iyz="0.0" izz="0.00001"/>
    </inertial>
  </link>
</robot>
